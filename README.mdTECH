
<!DOCTYPE html>
<html lang="sw">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Joshua Tech - Suluhisho la kisasa la teknolojia Tanzania. Tunatengeneza WhatsApp Bot, Website, Logo na zaidi.">
  <meta name="theme-color" content="#111827">
  <title>JOSHUA TECH - Suluhisho la Kisasa la Teknolojia</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      background: #0a0e1a;
      font-family: 'Poppins', sans-serif;
      color: #fff;
      padding: 20px;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .container {
      max-width: 450px;
      width: 100%;
      background: #111827;
      border-radius: 20px;
      padding: 28px;
      box-shadow: 0 10px 40px rgba(34, 211, 238, 0.1);
      border: 1px solid #1e293b;
    }
    
    .brand {
      text-align: center;
      font-size: 32px;
      font-weight: 700;
      color: #22d3ee;
      margin-bottom: 8px;
      letter-spacing: 1px;
    }
    
    .header h1 {
      font-size: 18px;
      font-weight: 600;
      margin: 12px 0;
      text-align: center;
    }
    
    .tagline {
      font-weight: 700;
      font-size: 20px;
      margin: 20px 0;
      text-align: center;
      color: #e5e7eb;
    }
    
    .desc {
      font-size: 14px;
      line-height: 1.7;
      color: #d1d5db;
      text-align: center;
      margin-bottom: 28px;
    }
    
    .huduma { margin: 28px 0; }
    
    .huduma-title {
      font-size: 18px;
      font-weight: 700;
      color: #22d3ee;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    
    .huduma-list {
      list-style: none;
      padding: 0;
    }
    
    .huduma-list li {
      font-size: 15px;
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 12px;
      color: #e5e7eb;
    }
    
    .huduma-list li::before {
      content: "✅";
      font-size: 16px;
      flex-shrink: 0;
    }
    
    .contact-box {
      background: #1f2937;
      border-radius: 14px;
      padding: 24px;
      margin-top: 28px;
      text-align: center;
      border: 1px solid #334155;
    }
    
    .contact-title {
      font-size: 19px;
      font-weight: 700;
      color: #22d3ee;
      margin-bottom: 16px;
    }
    
    .phone {
      font-size: 15px;
      font-weight: 600;
      margin: 12px 0;
      color: #fff;
      background: #0f172a;
      padding: 12px;
      border-radius: 10px;
      text-decoration: none;
      display: block;
    }
    
    .phone:hover { background: #1e293b; }
    
    .btn {
      display: block;
      background: #06b6d4;
      color: #fff;
      text-decoration: none;
      padding: 16px;
      border-radius: 12px;
      font-weight: 700;
      margin-top: 18px;
      transition: 0.3s;
      font-size: 16px;
    }
    
    .btn:hover {
      background: #0891b2;
      transform: translateY(-2px);
    }
    
    .footer {
      text-align: center;
      margin-top: 24px;
      font-size: 12px;
      color: #64748b;
    }
